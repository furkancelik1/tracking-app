generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid()) @db.VarChar(191)
  name             String?
  email            String?   @unique @db.VarChar(191)
  emailVerified    DateTime?
  image            String?
  subscriptionTier   String    @default("FREE") // PRO veya FREE
  emailNotificationsEnabled Boolean @default(true)
  stripeCustomerId   String?  @unique @db.VarChar(191)
  stripeSubscriptionId String? @unique @db.VarChar(191)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  routines         Routine[]
  logs             RoutineLog[]
}

model Routine {
  id              String       @id @default(cuid()) @db.VarChar(191)
  title           String       @db.VarChar(191)
  description     String?      @db.Text
  icon            String       @default("Check") @db.VarChar(191)
  category        String       @default("Genel") @db.VarChar(191)
  color           String       @default("#3b82f6") @db.VarChar(191)
  frequency       RoutineFrequency @default(DAILY)
  isActive        Boolean      @default(true)
  
  // Dashboard sıralaması için kritik alan
  sortOrder       Int          @default(0) 
  
  // Streak (Seri) Sistemi
  currentStreak   Int          @default(0)
  longestStreak   Int          @default(0)
  lastCompletedAt DateTime?
  
  userId          String       @db.VarChar(191)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  logs            RoutineLog[]

  @@index([userId])
}

model RoutineLog {
  id          String   @id @default(cuid()) @db.VarChar(191)
  completedAt DateTime @default(now())
  note        String?  @db.Text
  
  routineId   String   @db.VarChar(191)
  routine     Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  
  userId      String   @db.VarChar(191)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([routineId])
  @@index([userId])
}

enum RoutineFrequency {
  DAILY
  WEEKLY
  MONTHLY
}