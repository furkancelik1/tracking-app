generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  FREE
  PRO
}

enum RoutineFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// --- NIKE İÇİN EKLENEN YENİ ENUM ---
enum RoutineIntensity {
  LOW
  MEDIUM
  HIGH
}

enum ItemType {
  STREAK_FREEZE
}

enum BadgeCriteriaType {
  STREAK
  TOTAL_COMPLETIONS
  COIN_EARNED
  FIRST_HABIT
  ALL_DONE
  TOUR_COMPLETE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ChallengeStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
  EXPIRED
}

enum ShopItemCategory {
  THEME
  FRAME
  BOOSTER
}

enum DuelStatus {
  PENDING
  ACTIVE
  FINISHED
  DECLINED
  EXPIRED
}

model User {
  id                        String           @id @default(cuid())
  name                      String?
  email                     String?          @unique
  emailVerified             DateTime?
  image                     String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  subscriptionTier          SubscriptionTier @default(FREE)
  emailNotificationsEnabled Boolean          @default(true)
  stripeCustomerId          String?          @unique
  stripeSubscriptionId      String?          @unique
  stripeCurrentPeriodEnd    DateTime?
  reminderEnabled           Boolean          @default(false)
  reminderTime              String?
  reminderTimezone          String?

  xp                        Int              @default(0)
  level                     Int              @default(1)
  coins                     Int              @default(0)
  isPublic                  Boolean          @default(true)
  hasSeenTour               Boolean          @default(false)
  language                  String           @default("en")

  equippedTheme             String?
  equippedFrame             String?

  accounts                  Account[]
  sessions                  Session[]
  routines                  Routine[]
  routineLogs               RoutineLog[]
  userItems                 UserItem[]
  userBadges                UserBadge[]
  pushSubscriptions         PushSubscription[]

  // Social
  sentFollows               Friendship[]    @relation("FollowerRelation")
  receivedFollows           Friendship[]    @relation("FollowingRelation")
  sentChallenges            Challenge[]     @relation("ChallengerRelation")
  receivedChallenges        Challenge[]     @relation("OpponentRelation")
  challengeLogs             ChallengeLog[]
  weeklyInsights            WeeklyInsight[]
  purchases                 Purchase[]
  dailyCoachMessages        DailyCoachMessage[]

  // Duels
  sentDuels                 Duel[]          @relation("DuelChallengerRelation")
  receivedDuels             Duel[]          @relation("DuelOpponentRelation")
  currentDuelId             String?
  duelMessages              DuelMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], name: "provider_providerAccountId")
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Routine {
  id                    String               @id @default(cuid())
  userId                String
  title                 String
  description           String?
  icon                  String?              @default("Check")
  category              String               @default("Genel")
  color                 String?              @default("#3b82f6")
  frequency             RoutineFrequency     @default(DAILY)
  isActive              Boolean              @default(true)
  sortOrder             Int                  @default(0)
  currentStreak         Int                  @default(0)
  longestStreak         Int                  @default(0)
  lastCompletedAt       DateTime?
  
  // --- NIKE ELITE ALANLARI ---
  intensity             RoutineIntensity     @default(MEDIUM)
  estimatedMinutes      Int                  @default(0)
  imageUrl              String?
  isGuided              Boolean              @default(false)
  coachTip              String?              @db.Text
  // ---------------------------

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs                  RoutineLog[]

  @@index([userId])
  @@index([userId, isActive])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RoutineLog {
  id          String   @id @default(cuid())
  routineId   String
  userId      String
  completedAt DateTime @default(now())
  note        String?
  createdAt   DateTime @default(now())

  routine     Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([routineId])
  @@index([userId])
  @@index([routineId, completedAt])
  @@index([userId, completedAt])
}

model Item {
  id          String   @id @default(cuid())
  name        String   @unique
  type        ItemType
  price       Int
  description String?
  icon        String?
  userItems   UserItem[]
}

model UserItem {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

model Badge {
  id            String            @id @default(cuid())
  name          String            @unique
  description   String?
  icon          String?
  criteriaType  BadgeCriteriaType
  criteriaValue Int               @default(0)

  userBadges    UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Social: Friendship ──────────────────────────────────────────────────────

model Friendship {
  id          String           @id @default(cuid())
  followerId  String
  followingId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  follower    User @relation("FollowerRelation", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("FollowingRelation", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([followingId, status])
}

// ─── Social: Challenge (Düello) ──────────────────────────────────────────────

model Challenge {
  id                String          @id @default(cuid())
  challengerId      String
  opponentId        String
  routineTitle      String
  durationDays      Int             @default(7)
  status            ChallengeStatus @default(PENDING)
  startDate         DateTime?
  endDate           DateTime?
  winnerId          String?
  rewardDistributed Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  challenger    User            @relation("ChallengerRelation", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent      User            @relation("OpponentRelation", fields: [opponentId], references: [id], onDelete: Cascade)
  logs          ChallengeLog[]

  @@index([challengerId])
  @@index([opponentId])
  @@index([status])
}

model ChallengeLog {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  completedAt DateTime @default(now())

  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId, completedAt])
  @@index([challengeId])
  @@index([userId])
}

// ─── AI Weekly Insight Cache ─────────────────────────────────────────────────

model WeeklyInsight {
  id                   String   @id @default(cuid())
  userId               String
  weekKey              String   // "2026-W15" formatında (ISO hafta)
  locale               String   @default("en")
  summary              String   @db.Text
  chartAnalysis        String?  @db.Text
  challengeTitle       String?
  challengeDescription String?
  challengeCategory    String?
  challengeTarget      Int      @default(0)
  challengeProgress    Int      @default(0)
  challengeCompleted   Boolean  @default(false)
  successHighlight     String?
  createdAt            DateTime @default(now())

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekKey])
  @@index([userId])
}

// ─── AI Daily Coach Message Cache ────────────────────────────────────────────

model DailyCoachMessage {
  id        String   @id @default(cuid())
  userId    String
  dayKey    String   // "2026-04-12" formatında
  locale    String   @default("en")
  message   String   @db.Text
  coachTip  String?  @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([userId])
}

// ─── Shop & Marketplace ──────────────────────────────────────────────────────

model ShopItem {
  id          String           @id @default(cuid())
  name        String
  description String
  price       Int
  minLevel    Int              @default(0)
  category    ShopItemCategory
  imageUrl    String?
  metadata    Json?            // örn. { "primary": "#6C63FF", "secondary": "#3B3299" }
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())

  purchases   Purchase[]

  @@index([category])
}

model Purchase {
  id         String   @id @default(cuid())
  userId     String
  shopItemId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopItem ShopItem @relation(fields: [shopItemId], references: [id], onDelete: Cascade)

  @@unique([userId, shopItemId])
  @@index([userId])
}

// ─── Disiplin Düellosu (1v1 Duel) ───────────────────────────────────────────

model Duel {
  id            String     @id @default(cuid())
  challengerId  String
  opponentId    String?    // Özel düellolarda başlangıçta null olabilir
  stake         Int        // Ortaya konan altın miktarı
  status        DuelStatus @default(PENDING)
  startTime     DateTime?
  endTime       DateTime?  // startTime + 24 saat
  winnerId      String?
  challengerScore Int      @default(0)
  opponentScore   Int      @default(0)
  inviteCode    String?    @unique  // Özel düello davet kodu
  isPrivate     Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  challenger    User       @relation("DuelChallengerRelation", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent      User?      @relation("DuelOpponentRelation", fields: [opponentId], references: [id], onDelete: Cascade)
  messages      DuelMessage[]

  @@index([challengerId])
  @@index([opponentId])
  @@index([status])
  @@index([inviteCode])
}

model DuelMessage {
  id        String   @id @default(cuid())
  duelId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  duel      Duel     @relation(fields: [duelId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([duelId, createdAt])
  @@index([senderId])
}